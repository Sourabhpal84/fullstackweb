rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "magneeto73@gmail.com";
    }

    function validImage() {
      return request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /menu-images/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /whatsapp-campaigns/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
