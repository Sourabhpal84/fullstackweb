rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          "magneeto73@gmail.com",
          "sourabhpal982@gmail.com"
        ];
    }

    function validImage() {
      return request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && validImage();
    }

    match /dishes/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && validImage();
    }

    match /menu-images/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /menu-images/{folder}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /category-images/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /category-images/{folder}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /hero-images/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /hero-images/{folder}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /whatsapp-campaigns/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
